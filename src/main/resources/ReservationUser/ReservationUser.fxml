<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="800" prefWidth="1200"
            style="-fx-background-color: #F4F6F9;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.ReservationUserController">

    <!-- ================= HEADER ================= -->
    <top>
        <VBox spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="15"
                  style="-fx-background-color: linear-gradient(to right, #FF6B35, #F7931E); -fx-padding: 18 40;">
                <StackPane prefWidth="48" prefHeight="48"
                           style="-fx-background-color: rgba(255,255,255,0.22); -fx-background-radius: 12;">
                    <Label text="✈" style="-fx-font-size: 22px;"/>
                </StackPane>
                <VBox HBox.hgrow="ALWAYS" spacing="1">
                    <Label text="TripEase" textFill="white"
                           style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                    <Label text="Réservez votre offre de voyage idéale"
                           textFill="rgba(255,255,255,0.85)" style="-fx-font-size: 12px;"/>
                </VBox>

                <!-- BOUTON RETOUR (NOUVEAU) -->
                <Button fx:id="btnRetour"
                        text="← Retour"
                        onAction="#retourDashboard"
                        style="-fx-background-color: rgba(255,255,255,0.2);
                               -fx-text-fill: white;
                               -fx-font-size: 12px;
                               -fx-font-weight: bold;
                               -fx-padding: 8 16;
                               -fx-background-radius: 18;
                               -fx-border-color: rgba(255,255,255,0.45);
                               -fx-border-width: 1.5;
                               -fx-border-radius: 18;
                               -fx-cursor: hand;"/>

                <!-- BOUTON CONFIGURER VOYAGE -->
                <Button fx:id="configurerVoyageBtn"
                        text="⚙ Configurer nouveau voyage"
                        onAction="#ouvrirConfigurationVoyage"
                        style="-fx-background-color: white;
                               -fx-text-fill: #FF6B35;
                               -fx-font-size: 12px;
                               -fx-font-weight: bold;
                               -fx-padding: 8 16;
                               -fx-background-radius: 18;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 6, 0, 0, 2);"/>

                <!-- APRÈS -->
                <Label fx:id="labelEmail" text="👤 Chargement..." textFill="white"
                       style="-fx-font-size: 12px; -fx-padding: 7 14;
              -fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 18;"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="6"
                  style="-fx-background-color: white; -fx-padding: 10 40;
                         -fx-border-color: #E8E8E8; -fx-border-width: 0 0 1 0;">
                <Label text="🏠 Accueil" style="-fx-font-size: 12px; -fx-text-fill: #999;"/>
                <Label text="›" style="-fx-text-fill: #CCC;"/>
                <Label text="🎫 Offres"
                       style="-fx-font-size: 12px; -fx-text-fill: #FF6B35; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ================= CENTER ================= -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="0">

                <!-- Titre + Recherche -->
                <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-padding: 28 32 18 32;">
                    <StackPane prefWidth="46" prefHeight="46"
                               style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #FF6B35, #F7931E);
                                      -fx-background-radius: 13;">
                        <Label text="🎫" style="-fx-font-size: 20px;"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="Nos Offres de Voyage"
                               style="-fx-font-size: 21px; -fx-font-weight: bold; -fx-text-fill: #2C2C2C;"/>
                        <Label text="Découvrez et réservez l'offre qui vous correspond"
                               style="-fx-font-size: 13px; -fx-text-fill: #999;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- Recherche -->
                    <HBox spacing="0" alignment="CENTER"
                          style="-fx-background-color: white; -fx-background-radius: 10;
                                 -fx-border-color: #DCDCDC; -fx-border-radius: 10; -fx-border-width: 1.5;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                        <Label text="🔍" style="-fx-font-size: 14px; -fx-padding: 0 6 0 14;"/>
                        <TextField fx:id="searchField"
                                   promptText="Rechercher une offre..."
                                   prefWidth="240" prefHeight="40"
                                   style="-fx-background-color: transparent; -fx-border-color: transparent;
                                          -fx-font-size: 13px; -fx-padding: 0 14 0 4;"/>
                    </HBox>
                </HBox>

                <!-- Grille offres -->
                <VBox spacing="16" style="-fx-padding: 0 32 32 32;">
                    <VBox spacing="16"
                          style="-fx-background-color: white; -fx-background-radius: 14;
                                 -fx-border-color: #ECECEC; -fx-border-radius: 14; -fx-border-width: 1;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 3);">
                        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <StackPane prefWidth="36" prefHeight="36"
                                       style="-fx-background-color: #FFF3E0; -fx-background-radius: 10;">
                                <Label text="🎫" style="-fx-font-size: 16px;"/>
                            </StackPane>
                            <VBox spacing="1" HBox.hgrow="ALWAYS">
                                <Label text="Offres disponibles"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                                <Label text="Cliquez sur une offre pour voir les détails"
                                       style="-fx-font-size: 11.5px; -fx-text-fill: #AAA;"/>
                            </VBox>
                            <Button onAction="#refreshOffres"
                                    style="-fx-background-color: #FF6B35; -fx-text-fill: white;
                                           -fx-font-size: 13px; -fx-background-radius: 8;
                                           -fx-cursor: hand; -fx-padding: 8 16;"
                                    text="🔄  Rafraîchir"/>
                        </HBox>

                        <Separator/>

                        <ScrollPane fitToWidth="true" prefHeight="560" hbarPolicy="NEVER"
                                    style="-fx-background-color: transparent; -fx-background: transparent;
                                           -fx-border-color: transparent;">
                            <content>
                                <VBox spacing="0" style="-fx-background-color: transparent;">
                                    <FlowPane fx:id="offresGrid"
                                              hgap="18" vgap="18"
                                              prefWrapLength="900"
                                              style="-fx-background-color: transparent; -fx-padding: 4;"/>
                                    <VBox fx:id="emptyBox"
                                          alignment="CENTER" spacing="12"
                                          prefHeight="260"
                                          visible="false" managed="false">
                                        <Label text="🏖" style="-fx-font-size: 52px;"/>
                                        <Label text="Aucune offre disponible"
                                               style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #BBB;"/>
                                        <Label text="Revenez plus tard pour découvrir nos offres"
                                               style="-fx-font-size: 12px; -fx-text-fill: #CCC;"/>
                                    </VBox>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </VBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>