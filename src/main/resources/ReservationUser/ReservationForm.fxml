<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<BorderPane prefHeight="800" prefWidth="1100"
            style="-fx-background-color: #F4F6F9;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.ReservationFormController">

    <!-- ═══════════════════ HEADER ═══════════════════ -->
    <top>
        <VBox spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="15"
                  style="-fx-background-color: linear-gradient(to right, #FF6B35, #F7931E); -fx-padding: 18 40;">
                <StackPane prefWidth="48" prefHeight="48"
                           style="-fx-background-color: rgba(255,255,255,0.22); -fx-background-radius: 12;">
                    <Label text="🛒" style="-fx-font-size: 22px;"/>
                </StackPane>
                <VBox HBox.hgrow="ALWAYS" spacing="1">
                    <Label text="TripEase" textFill="white"
                           style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                    <Label text="Finaliser votre réservation"
                           textFill="rgba(255,255,255,0.85)" style="-fx-font-size: 12px;"/>
                </VBox>
                <Label text="👤 Utilisateur" textFill="white"
                       style="-fx-font-size: 12px; -fx-padding: 7 14;
                              -fx-background-color: rgba(255,255,255,0.15);
                              -fx-background-radius: 18;"/>
            </HBox>

            <!-- Breadcrumb -->
            <HBox alignment="CENTER_LEFT" spacing="6"
                  style="-fx-background-color: white; -fx-padding: 10 40;
                         -fx-border-color: #E8E8E8; -fx-border-width: 0 0 1 0;">
                <Label text="🏠 Accueil" style="-fx-font-size: 12px; -fx-text-fill: #999;"/>
                <Label text="›" style="-fx-text-fill: #CCC;"/>
                <Label text="🎫 Offres" style="-fx-font-size: 12px; -fx-text-fill: #999;"/>
                <Label text="›" style="-fx-text-fill: #CCC;"/>
                <Label text="🛒 Réservation"
                       style="-fx-font-size: 12px; -fx-text-fill: #FF6B35; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ═══════════════════ CENTER ═══════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="20" style="-fx-padding: 28 32 40 32;">

                <!-- Titre page -->
                <HBox alignment="CENTER_LEFT" spacing="14">
                    <StackPane prefWidth="46" prefHeight="46"
                               style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #FF6B35, #F7931E);
                                      -fx-background-radius: 13;">
                        <Label text="🛒" style="-fx-font-size: 20px;"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="Réserver cette offre"
                               style="-fx-font-size: 21px; -fx-font-weight: bold; -fx-text-fill: #2C2C2C;"/>
                        <Label text="Vérifiez les détails et remplissez le formulaire ci-dessous"
                               style="-fx-font-size: 13px; -fx-text-fill: #999;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button onAction="#retourOffres"
                            style="-fx-background-color: white; -fx-text-fill: #FF6B35;
                                   -fx-border-color: #FF6B35; -fx-border-radius: 8;
                                   -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-font-size: 12px; -fx-padding: 8 16;"
                            text="← Retour aux offres"/>
                </HBox>

                <!-- ══ CONTENU PRINCIPAL (2 colonnes) ══ -->
                <HBox spacing="20" alignment="TOP_LEFT">

                    <!-- ─── Colonne gauche : Résumé offre ─── -->
                    <VBox spacing="16" prefWidth="360" minWidth="320">

                        <!-- Card résumé offre -->
                        <VBox spacing="0"
                              style="-fx-background-color: white; -fx-background-radius: 14;
                                     -fx-border-color: #ECECEC; -fx-border-radius: 14; -fx-border-width: 1;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 3);">

                            <!-- Image offre -->
                            <StackPane fx:id="imagePane" prefHeight="180"
                                       style="-fx-background-color: #FFF3E0;
                                              -fx-background-radius: 14 14 0 0;">
                                <ImageView fx:id="offreImageView"
                                           fitWidth="360" fitHeight="180"
                                           preserveRatio="false" smooth="true"/>
                                <Label fx:id="imagePlaceholder" text="🏖"
                                       style="-fx-font-size: 48px;"/>
                                <!-- Badge type -->
                                <VBox alignment="BOTTOM_LEFT" style="-fx-padding: 0 0 12 12;">
                                    <Label fx:id="typeBadge" text="OFFRE"
                                           style="-fx-background-color: #FF6B35; -fx-text-fill: white;
                                                  -fx-font-size: 10px; -fx-font-weight: bold;
                                                  -fx-background-radius: 5; -fx-padding: 3 10;"/>
                                </VBox>
                            </StackPane>

                            <!-- Infos offre -->
                            <VBox spacing="12" style="-fx-padding: 18 20 18 20;">
                                <Label fx:id="offreTitreLabel"
                                       text="Chargement..."
                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2C2C2C;"
                                       wrapText="true"/>
                                <Label fx:id="offreDescLabel"
                                       text=""
                                       style="-fx-font-size: 12px; -fx-text-fill: #777;"
                                       wrapText="true"/>

                                <Separator/>

                                <!-- Destination -->
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="🌍" style="-fx-font-size: 14px;"/>
                                    <VBox spacing="1">
                                        <Label text="Destination"
                                               style="-fx-font-size: 10px; -fx-text-fill: #AAA; -fx-font-weight: bold;"/>
                                        <Label fx:id="destinationLabel" text="—"
                                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                                    </VBox>
                                </HBox>

                                <!-- Dates -->
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="📅" style="-fx-font-size: 14px;"/>
                                    <VBox spacing="1">
                                        <Label text="Période"
                                               style="-fx-font-size: 10px; -fx-text-fill: #AAA; -fx-font-weight: bold;"/>
                                        <Label fx:id="datesLabel" text="—"
                                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                                    </VBox>
                                </HBox>

                                <!-- Hôtel -->
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="🏨" style="-fx-font-size: 14px;"/>
                                    <VBox spacing="1">
                                        <Label text="Hôtel"
                                               style="-fx-font-size: 10px; -fx-text-fill: #AAA; -fx-font-weight: bold;"/>
                                        <Label fx:id="hotelLabel" text="—"
                                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                                    </VBox>
                                </HBox>

                                <!-- Vol -->
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="✈" style="-fx-font-size: 14px;"/>
                                    <VBox spacing="1">
                                        <Label text="Vol"
                                               style="-fx-font-size: 10px; -fx-text-fill: #AAA; -fx-font-weight: bold;"/>
                                        <Label fx:id="volLabel" text="—"
                                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                                    </VBox>
                                </HBox>

                                <!-- Activité -->
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="🎯" style="-fx-font-size: 14px;"/>
                                    <VBox spacing="1">
                                        <Label text="Activité"
                                               style="-fx-font-size: 10px; -fx-text-fill: #AAA; -fx-font-weight: bold;"/>
                                        <Label fx:id="activiteLabel" text="—"
                                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                                    </VBox>
                                </HBox>

                                <Separator/>

                                <!-- Prix par personne -->
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="💰 Prix par personne :"
                                           style="-fx-font-size: 13px; -fx-text-fill: #666;"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="prixUnitaireLabel" text="0 €"
                                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #FF6B35;"/>
                                </HBox>
                            </VBox>
                        </VBox>

                    </VBox>

                    <!-- ─── Colonne droite : Formulaire ─── -->
                    <VBox spacing="16" HBox.hgrow="ALWAYS">

                        <!-- Card formulaire -->
                        <VBox spacing="16"
                              style="-fx-background-color: white; -fx-background-radius: 14;
                                     -fx-border-color: #ECECEC; -fx-border-radius: 14; -fx-border-width: 1;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 3);">
                            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

                            <!-- Titre formulaire -->
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <StackPane prefWidth="36" prefHeight="36"
                                           style="-fx-background-color: #FFF3E0; -fx-background-radius: 10;">
                                    <Label text="📋" style="-fx-font-size: 16px;"/>
                                </StackPane>
                                <Label text="Informations de réservation"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                            </HBox>

                            <Separator/>

                            <!-- Nombre de personnes -->
                            <VBox spacing="6">
                                <Label text="👥  Nombre de personnes"
                                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #555;"/>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Spinner fx:id="nbPersonnesSpinner"
                                             min="1" max="20" initialValue="1"
                                             editable="true" prefWidth="120"
                                             style="-fx-font-size: 13px; -fx-background-radius: 8;
                                                    -fx-border-color: #DDD; -fx-border-radius: 8;"/>
                                    <Label text="personne(s) — modifiez pour recalculer le total"
                                           style="-fx-font-size: 11px; -fx-text-fill: #AAA;"/>
                                </HBox>
                            </VBox>

                            <!-- Date de réservation -->
                            <VBox spacing="6">
                                <Label text="📅  Date de réservation"
                                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #555;"/>
                                <DatePicker fx:id="datePicker" prefWidth="220"
                                            style="-fx-font-size: 13px; -fx-background-radius: 8;
                                                   -fx-border-color: #DDD; -fx-border-radius: 8;"/>
                            </VBox>


                            <!-- Commentaire -->
                            <VBox spacing="6">
                                <Label text="💬  Commentaire (optionnel)"
                                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #555;"/>
                                <TextArea fx:id="commentaireArea"
                                          promptText="Remarques ou demandes spéciales..."
                                          prefRowCount="3" wrapText="true"
                                          style="-fx-font-size: 12.5px; -fx-background-radius: 8;
                                                 -fx-border-color: #DDD; -fx-border-radius: 8;"/>
                            </VBox>

                            <!-- Message erreur -->
                            <Label fx:id="errorLabel" text=""
                                   visible="false" managed="false"
                                   style="-fx-text-fill: #E74C3C; -fx-font-size: 12px;
                                          -fx-background-color: #FFEBEE; -fx-background-radius: 6;
                                          -fx-padding: 8 14; -fx-font-weight: bold;"
                                   wrapText="true"/>

                        </VBox>

                        <!-- Card total -->
                        <VBox spacing="12"
                              style="-fx-background-color: white; -fx-background-radius: 14;
                                     -fx-border-color: #FFCDB0; -fx-border-radius: 14; -fx-border-width: 1.5;
                                     -fx-effect: dropshadow(gaussian, rgba(255,107,53,0.1), 12, 0, 0, 3);">
                            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <StackPane prefWidth="36" prefHeight="36"
                                           style="-fx-background-color: #FFF3E0; -fx-background-radius: 10;">
                                    <Label text="💰" style="-fx-font-size: 16px;"/>
                                </StackPane>
                                <Label text="Récapitulatif du prix"
                                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #FF6B35;"/>
                            </HBox>

                            <Separator/>

                            <!-- Ligne détail prix -->
                            <HBox alignment="CENTER_LEFT">
                                <Label fx:id="prixDetailLabel"
                                       text="0 € × 1 personne"
                                       style="-fx-font-size: 13px; -fx-text-fill: #777;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="totalLabel" text="0 €"
                                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #FF6B35;"/>
                            </HBox>

                            <Separator/>

                            <!-- Boutons -->
                            <HBox spacing="12" alignment="CENTER_RIGHT">
                                <Button onAction="#retourOffres"
                                        style="-fx-background-color: #F0F0F0; -fx-text-fill: #666;
                                               -fx-background-radius: 10; -fx-cursor: hand;
                                               -fx-font-size: 13px; -fx-padding: 12 24;"
                                        text="✕  Annuler"/>
                                <Button fx:id="confirmerBtn" onAction="#confirmerReservation"
                                        style="-fx-background-color: linear-gradient(to right, #FF6B35, #F7931E);
                                               -fx-text-fill: white; -fx-background-radius: 10;
                                               -fx-cursor: hand; -fx-font-size: 13px;
                                               -fx-font-weight: bold; -fx-padding: 12 28;
                                               -fx-effect: dropshadow(gaussian, rgba(255,107,53,0.4), 10, 0, 0, 3);"
                                        text="✅  Confirmer la réservation"/>
                            </HBox>

                        </VBox>
                    </VBox>

                </HBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
