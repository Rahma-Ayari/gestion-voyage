<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.ImageView?>

<BorderPane prefWidth="1100" prefHeight="700" minWidth="1100" minHeight="700"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.OffreController"
            style="-fx-background-color: linear-gradient(to bottom, #f5f7fa, #c3cfe2);">

    <!-- ================= TOP HEADER ================= -->
    <top>
        <VBox spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: linear-gradient(to right, #FF6B35, #F7931E);
                         -fx-padding: 12 20 12 20;">
                <StackPane prefWidth="40" prefHeight="40"
                           style="-fx-background-color: white;
                                  -fx-background-radius: 12;
                                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 8, 0, 0, 3);">
                    <ImageView fitHeight="36" fitWidth="36" preserveRatio="true" smooth="true"/>
                </StackPane>
                <Separator orientation="VERTICAL"
                           style="-fx-background-color: rgba(255,255,255,0.3);"
                           prefHeight="30"/>
                <VBox alignment="CENTER_LEFT" spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="TripEase" textFill="white"
                           style="-fx-font-size: 20px; -fx-font-weight: bold;
                                  -fx-font-family: 'Segoe UI', Arial;
                                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 2, 0, 0, 1);"/>
                    <Label text="Gestion des Offres" textFill="rgba(255,255,255,0.95)">
                        <font><Font name="Segoe UI Semibold" size="12"/></font>
                    </Label>
                </VBox>
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Label text="👤 Admin" textFill="white"
                           style="-fx-font-size: 11px; -fx-padding: 6 12;
                                  -fx-background-color: rgba(255,255,255,0.2);
                                  -fx-background-radius: 20;"/>
                </HBox>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="8"
                  style="-fx-background-color: white; -fx-padding: 8 20;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                <Label text="🏠 Accueil"
                       style="-fx-font-size: 11px; -fx-text-fill: #666; -fx-padding: 4 12;"/>
                <Label text=">" style="-fx-text-fill: #ccc;"/>
                <Label text="🎫 Offres"
                       style="-fx-font-size: 11px; -fx-text-fill: #FF6B35;
                              -fx-font-weight: bold; -fx-padding: 4 12;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ================= LEFT FORM ================= -->
    <left>
        <ScrollPane prefWidth="290" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-padding: 8;">
            <content>
                <VBox spacing="8" maxHeight="Infinity" maxWidth="270" alignment="TOP_CENTER"
                      style="-fx-background-color: white;
                             -fx-background-radius: 15;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 5);">
                    <padding>
                        <Insets top="15" right="12" bottom="15" left="12"/>
                    </padding>

                    <Label text="📝 Ajouter une Offre" textFill="#FF6B35">
                        <font><Font name="Segoe UI Bold" size="16"/></font>
                    </Label>

                    <Separator/>

                    <!-- Type -->
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="🏷" style="-fx-font-size: 14px;"/>
                        <TextField fx:id="typeField"
                                   promptText="Type d'offre"
                                   prefWidth="220"
                                   style="-fx-background-radius: 8; -fx-border-color: #ddd;
                                          -fx-border-radius: 8; -fx-padding: 6; -fx-font-size: 11px;"/>
                    </HBox>

                    <!-- Prix -->
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="💰" style="-fx-font-size: 14px;"/>
                        <TextField fx:id="prixField"
                                   promptText="Prix (€)"
                                   prefWidth="220"
                                   style="-fx-background-radius: 8; -fx-border-color: #ddd;
                                          -fx-border-radius: 8; -fx-padding: 6; -fx-font-size: 11px;"/>
                    </HBox>

                    <!-- Description -->
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="📄" style="-fx-font-size: 14px;"/>
                        <TextArea fx:id="descriptionArea"
                                  promptText="Description..."
                                  prefWidth="220"
                                  prefRowCount="2"
                                  wrapText="true"
                                  style="-fx-background-radius: 8; -fx-border-color: #ddd;
                                         -fx-border-radius: 8; -fx-padding: 6; -fx-font-size: 11px;"/>
                    </HBox>

                    <!-- Disponibilité -->
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="✅" style="-fx-font-size: 14px;"/>
                        <CheckBox fx:id="disponibiliteCheck" text="Disponible">
                            <font><Font name="Segoe UI" size="11"/></font>
                        </CheckBox>
                    </HBox>

                    <Separator/>

                    <!-- Date Début -->
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="📅" style="-fx-font-size: 14px;"/>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Date de début"
                                   style="-fx-font-size: 9px; -fx-text-fill: #888; -fx-font-weight: bold;"/>
                            <DatePicker fx:id="dateDebutPicker"
                                        promptText="jj/mm/aaaa"
                                        prefWidth="220"
                                        style="-fx-background-radius: 8; -fx-border-color: #ddd;
                                               -fx-border-radius: 8; -fx-font-size: 10px;"/>
                        </VBox>
                    </HBox>

                    <!-- Date Fin -->
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="🏁" style="-fx-font-size: 14px;"/>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Date de fin"
                                   style="-fx-font-size: 9px; -fx-text-fill: #888; -fx-font-weight: bold;"/>
                            <DatePicker fx:id="dateFinPicker"
                                        promptText="jj/mm/aaaa"
                                        prefWidth="220"
                                        style="-fx-background-radius: 8; -fx-border-color: #ddd;
                                               -fx-border-radius: 8; -fx-font-size: 10px;"/>
                        </VBox>
                    </HBox>

                    <Separator/>

                    <!-- Destination -->
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="🌍" style="-fx-font-size: 14px;"/>
                        <ComboBox fx:id="destinationCombo"
                                  promptText="Destination"
                                  prefWidth="220"
                                  style="-fx-background-radius: 8; -fx-border-color: #ddd;
                                         -fx-border-radius: 8; -fx-padding: 4; -fx-font-size: 10px;"/>
                    </HBox>

                    <!-- Vol -->
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="🛫" style="-fx-font-size: 14px;"/>
                        <ComboBox fx:id="volCombo"
                                  promptText="Vol"
                                  prefWidth="220"
                                  style="-fx-background-radius: 8; -fx-border-color: #ddd;
                                         -fx-border-radius: 8; -fx-padding: 4; -fx-font-size: 10px;"/>
                    </HBox>

                    <!-- Hotel -->
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="🏨" style="-fx-font-size: 14px;"/>
                        <ComboBox fx:id="hotelCombo"
                                  promptText="Hôtel"
                                  prefWidth="220"
                                  style="-fx-background-radius: 8; -fx-border-color: #ddd;
                                         -fx-border-radius: 8; -fx-padding: 4; -fx-font-size: 10px;"/>
                    </HBox>

                    <!-- Activité -->
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="🎯" style="-fx-font-size: 14px;"/>
                        <ComboBox fx:id="activiteCombo"
                                  promptText="Activité"
                                  prefWidth="220"
                                  style="-fx-background-radius: 8; -fx-border-color: #ddd;
                                         -fx-border-radius: 8; -fx-padding: 4; -fx-font-size: 10px;"/>
                    </HBox>

                    <Separator/>

                    <!-- ================= IMAGE ================= -->
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="🖼" style="-fx-font-size: 14px;"/>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <HBox spacing="5" alignment="CENTER_LEFT">
                                <TextField fx:id="imagePathField"
                                           promptText="Chemin..."
                                           prefWidth="140"
                                           editable="false"
                                           style="-fx-background-radius: 8; -fx-border-color: #ddd;
                                                  -fx-border-radius: 8; -fx-padding: 5;
                                                  -fx-font-size: 9px; -fx-text-fill: #555;"/>
                                <Button fx:id="browseImageBtn"
                                        text="📁"
                                        onAction="#browseImage"
                                        style="-fx-background-color: #FF6B35; -fx-text-fill: white;
                                               -fx-font-weight: bold; -fx-font-size: 11px;
                                               -fx-background-radius: 8; -fx-cursor: hand;
                                               -fx-padding: 5 8;"/>
                            </HBox>

                            <!-- Zone de prévisualisation -->
                            <StackPane fx:id="imagePreviewPane"
                                       prefWidth="220" prefHeight="100"
                                       style="-fx-background-color: #f9f9f9;
                                              -fx-background-radius: 8;
                                              -fx-border-color: #ddd;
                                              -fx-border-radius: 8;
                                              -fx-border-style: dashed;
                                              -fx-border-width: 2;">
                                <VBox alignment="CENTER" spacing="4">
                                    <Label fx:id="imagePlaceholderLabel"
                                           text="📷"
                                           style="-fx-font-size: 24px;"/>
                                    <Label text="Aucune image"
                                           style="-fx-text-fill: #bbb; -fx-font-size: 9px;"/>
                                </VBox>
                                <ImageView fx:id="imagePreview"
                                           fitWidth="216" fitHeight="96"
                                           preserveRatio="true"
                                           smooth="true"
                                           visible="false"/>
                            </StackPane>

                            <!-- Bouton effacer image -->
                            <Button fx:id="clearImageBtn"
                                    text="✕ Effacer"
                                    onAction="#clearImage"
                                    prefWidth="220"
                                    style="-fx-background-color: transparent;
                                           -fx-border-color: #ddd; -fx-border-radius: 8;
                                           -fx-text-fill: #999; -fx-font-size: 9px;
                                           -fx-cursor: hand; -fx-padding: 4;"/>
                        </VBox>
                    </HBox>

                    <Separator/>

                    <!-- Buttons -->
                    <HBox spacing="6" alignment="CENTER">
                        <VBox spacing="6">
                            <Button fx:id="ajouterBtn"
                                    text="➕ Ajouter"
                                    prefWidth="105" prefHeight="30"
                                    onAction="#ajouterOffre"
                                    style="-fx-background-color: #4CAF50; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-font-size: 10px;
                                           -fx-background-radius: 8; -fx-cursor: hand;"/>
                            <Button fx:id="modifierBtn"
                                    text="✏ Modifier"
                                    prefWidth="105" prefHeight="30"
                                    onAction="#modifierOffre"
                                    style="-fx-background-color: #2196F3; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-font-size: 10px;
                                           -fx-background-radius: 8; -fx-cursor: hand;"/>
                        </VBox>
                        <VBox spacing="6">
                            <Button fx:id="supprimerBtn"
                                    text="🗑 Supprimer"
                                    prefWidth="105" prefHeight="30"
                                    onAction="#supprimerOffre"
                                    style="-fx-background-color: #f44336; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-font-size: 10px;
                                           -fx-background-radius: 8; -fx-cursor: hand;"/>
                            <Button fx:id="clearBtn"
                                    text="🔄 Effacer"
                                    prefWidth="105" prefHeight="30"
                                    onAction="#clearFields"
                                    style="-fx-background-color: #9E9E9E; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-font-size: 10px;
                                           -fx-background-radius: 8; -fx-cursor: hand;"/>
                        </VBox>
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </left>

    <!-- ================= CENTER TABLE ================= -->
    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="15" left="10"/>
            </padding>

            <!-- Search Bar -->
            <HBox spacing="8" alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-background-radius: 10;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                <padding>
                    <Insets top="8" right="8" bottom="8" left="8"/>
                </padding>
                <Label text="🔍" style="-fx-font-size: 14px;"/>
                <TextField fx:id="searchField"
                           promptText="Rechercher une offre..."
                           prefWidth="500"
                           style="-fx-background-radius: 8; -fx-border-color: #ddd;
                                  -fx-border-radius: 8; -fx-padding: 8; -fx-font-size: 11px;"/>
                <Button fx:id="refreshBtn"
                        text="🔄"
                        onAction="#refreshTable"
                        style="-fx-background-color: #FF6B35; -fx-text-fill: white;
                               -fx-font-size: 14px; -fx-background-radius: 50%;
                               -fx-padding: 6 10; -fx-cursor: hand;"/>
            </HBox>

            <!-- Table -->
            <TableView fx:id="tableView"
                       VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-background-radius: 10;
                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 5);">
                <columns>
                    <TableColumn fx:id="typeCol"          text="Type"        prefWidth="70"/>
                    <TableColumn fx:id="prixCol"          text="Prix"        prefWidth="55"/>
                    <TableColumn fx:id="descriptionCol"   text="Description" prefWidth="100"/>
                    <TableColumn fx:id="disponibiliteCol" text="Dispo"       prefWidth="50"/>
                    <TableColumn fx:id="dateDebutCol"     text="Début"       prefWidth="75"/>
                    <TableColumn fx:id="dateFinCol"       text="Fin"         prefWidth="75"/>
                    <TableColumn fx:id="voyageCol"        text="Voyage"      prefWidth="70"/>
                    <TableColumn fx:id="destinationCol"   text="Dest."       prefWidth="70"/>
                    <TableColumn fx:id="volCol"           text="Vol"         prefWidth="60"/>
                    <TableColumn fx:id="hotelCol"         text="Hôtel"       prefWidth="60"/>
                    <TableColumn fx:id="activiteCol"      text="Activité"    prefWidth="70"/>
                    <TableColumn fx:id="imageCol"         text="Img"         prefWidth="45"/>
                </columns>
                <placeholder>
                    <Label text="Aucune offre trouvée"/>
                </placeholder>
            </TableView>

            <!-- Stats -->
            <HBox spacing="20" alignment="CENTER"
                  style="-fx-background-color: white; -fx-background-radius: 10;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                <padding>
                    <Insets top="10" right="12" bottom="10" left="12"/>
                </padding>
                <HBox spacing="4">
                    <Label text="📊 Total : ">
                        <font><Font name="Segoe UI Bold" size="11"/></font>
                    </Label>
                    <Label fx:id="countLabel" text="0" textFill="#FF6B35">
                        <font><Font name="Segoe UI Bold" size="14"/></font>
                    </Label>
                </HBox>
                <HBox spacing="4">
                    <Label text="✅ Disponibles : ">
                        <font><Font name="Segoe UI Bold" size="11"/></font>
                    </Label>
                    <Label fx:id="disponiblesLabel" text="0" textFill="#4CAF50">
                        <font><Font name="Segoe UI Bold" size="14"/></font>
                    </Label>
                </HBox>
                <HBox spacing="4">
                    <Label text="❌ Non dispo : ">
                        <font><Font name="Segoe UI Bold" size="11"/></font>
                    </Label>
                    <Label fx:id="nonDisponiblesLabel" text="0" textFill="#f44336">
                        <font><Font name="Segoe UI Bold" size="14"/></font>
                    </Label>
                </HBox>
            </HBox>
        </VBox>
    </center>

</BorderPane>
