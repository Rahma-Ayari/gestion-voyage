<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.web.WebView?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.HotelController"
            prefWidth="1100"
            prefHeight="700"
            maxWidth="1100"
            maxHeight="700"
            style="-fx-background-color: linear-gradient(to bottom, #f5f7fa, #c3cfe2);">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: linear-gradient(to right, #FF9800, #FFA726);
                     -fx-background-radius: 0 0 12 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 8, 0, 0, 4);">
            <padding><Insets bottom="15" left="25" right="25" top="15" /></padding>
            <Label text="TripEase" textFill="WHITE">
                <font><Font name="Segoe UI Bold" size="28" /></font>
            </Label>
            <Label text="Gestion des Hôtels" textFill="WHITE">
                <font><Font name="Segoe UI" size="22" /></font>
            </Label>
        </HBox>
    </top>

    <!-- Left Panel - Form -->
    <left>
        <ScrollPane fitToWidth="true" prefWidth="320" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-padding: 10;">
            <content>
                <VBox alignment="TOP_CENTER" maxWidth="300" prefWidth="300" spacing="10"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 6, 0, 0, 4);">
                    <padding><Insets top="20" right="15" bottom="20" left="15"/></padding>

                    <Label text="📝 Ajouter / Modifier un Hôtel">
                        <font><Font name="Segoe UI Bold" size="14"/></font>
                    </Label>
                    <Separator/>

                    <!-- Champs -->
                    <VBox spacing="8">
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 14px;" text="🏨"/>
                            <TextField fx:id="nomField" prefWidth="260" promptText="Nom de l'hôtel"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 14px;" text="🌆"/>
                            <TextField fx:id="villeField" prefWidth="260" promptText="Ville"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 14px;" text="📍"/>
                            <TextField fx:id="adresseField" prefWidth="260" promptText="Adresse"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 14px;" text="⭐"/>
                            <TextField fx:id="starsField" prefWidth="260" promptText="Étoiles (1-5)"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 14px;" text="🛏️"/>
                            <TextField fx:id="capaciteField" prefWidth="260" promptText="Capacité (chambres)"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 14px;" text="🛎️"/>
                            <TextField fx:id="typeChambreField" prefWidth="260" promptText="Type de chambre"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 14px;" text="💰"/>
                            <TextField fx:id="prixParNuitField" prefWidth="260" promptText="Prix par nuit"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 14px;" text="📌"/>
                            <TextField fx:id="latitudeField" prefWidth="260" promptText="Latitude (auto si vide)"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 14px;" text="📌"/>
                            <TextField fx:id="longitudeField" prefWidth="260" promptText="Longitude (auto si vide)"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 14px;" text="✔️"/>
                            <CheckBox fx:id="disponibiliteCheckBox" text="Disponible"/>
                        </HBox>
                    </VBox>

                    <Separator/>

                    <!-- Boutons CRUD -->
                    <HBox alignment="CENTER" spacing="10">
                        <Button onAction="#ajouterHotel" text="➕ Ajouter"
                                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 12;"/>
                        <Button onAction="#modifierHotel" text="✏️ Modifier"
                                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 12;"/>
                    </HBox>
                    <HBox alignment="CENTER" spacing="10">
                        <Button onAction="#supprimerHotel" text="🗑️ Supprimer"
                                style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 12;"/>
                        <Button onAction="#clearFields" text="🧹 Effacer"
                                style="-fx-background-color: #9E9E9E; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 12;"/>
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </left>

    <!-- Center Panel -->
    <center>
        <VBox spacing="10">
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

            <!-- Barre recherche -->
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label style="-fx-font-size: 14px;" text="🔍"/>
                <TextField fx:id="searchField" prefWidth="250" promptText="Rechercher un hôtel..."/>
                <Button onAction="#refreshTable" text="🔄 Rafraîchir"
                        style="-fx-background-color: #607D8B; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 5 12;"/>
                <Label text="Total :" style="-fx-font-weight: bold;"/>
                <Label fx:id="countLabel" text="0"
                       style="-fx-font-weight: bold; -fx-text-fill: #FF9800; -fx-font-size: 14px;"/>
            </HBox>

            <!-- Table -->
            <TableView fx:id="tableView" prefHeight="240" VBox.vgrow="NEVER">
                <columns>
                    <TableColumn fx:id="nomCol"          text="Nom"         prefWidth="100" />
                    <TableColumn fx:id="villeCol"        text="Ville"       prefWidth="80"  />
                    <TableColumn fx:id="adresseCol"      text="Adresse"     prefWidth="130" />
                    <TableColumn fx:id="starsCol"        text="⭐"          prefWidth="40"  />
                    <TableColumn fx:id="capaciteCol"     text="Capacité"    prefWidth="60"  />
                    <TableColumn fx:id="typeChambreCol"  text="Type"        prefWidth="80"  />
                    <TableColumn fx:id="prixParNuitCol"  text="Prix/Nuit"   prefWidth="70"  />
                    <TableColumn fx:id="latitudeCol"     text="Latitude"    prefWidth="80"  />
                    <TableColumn fx:id="longitudeCol"    text="Longitude"   prefWidth="80"  />
                    <TableColumn fx:id="disponibiliteCol" text="Disponible" prefWidth="70" />
                    <TableColumn fx:id="carteCol" text="📍 Carte" prefWidth="80" />
                </columns>
                <placeholder><Label text="Aucun hôtel trouvé"/></placeholder>
            </TableView>

            <!-- WebView Carte -->
            <Label text="🗺️ Localisation sur la carte" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
            <WebView fx:id="mapView" prefHeight="300" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>

</BorderPane>