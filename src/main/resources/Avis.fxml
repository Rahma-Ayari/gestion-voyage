<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.AvisController"
            style="-fx-background-color: #f4f7fb;">

    <top>
        <VBox spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="20"
                  style="-fx-background-color:linear-gradient(to right,#FF6B35,#F7931E);
                         -fx-padding:24 50;">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="TripEase Admin"
                           style="-fx-font-size:30px;-fx-font-weight:bold;
                                  -fx-text-fill:white;"/>
                    <Label text="Modération des Avis &amp; Gestion des Voyages"
                           style="-fx-font-size:14px;
                                  -fx-text-fill:rgba(255,255,255,0.9);"/>
                </VBox>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT"
                  style="-fx-background-color:white;-fx-padding:10 50;
                         -fx-border-color:#e0e0e0;-fx-border-width:0 0 1 0;">
                <Label text="🏠 Accueil"
                       style="-fx-text-fill:#888;-fx-font-size:13px;"/>
                <Label text="›" style="-fx-text-fill:#ccc;"/>
                <Label text="Gestion des Avis"
                       style="-fx-text-fill:#FF6B35;-fx-font-weight:bold;
                              -fx-font-size:13px;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color:#f4f7fb;-fx-background:#f4f7fb;">
            <VBox spacing="30" style="-fx-background-color:#f4f7fb;">
                <padding>
                    <Insets top="30" right="50" bottom="40" left="50"/>
                </padding>

                <!-- ══ SECTION 1 : Gestion état utilisateurs ══ -->
                <VBox spacing="16"
                      style="-fx-background-color:white;-fx-background-radius:14;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),14,0,0,5);
                             -fx-padding:28;">

                    <Label text="👥 Gestion des voyages utilisateurs"
                           style="-fx-font-size:18px;-fx-font-weight:bold;
                                  -fx-text-fill:#2c3e50;"/>
                    <Label text="Sélectionnez un utilisateur puis marquez son voyage comme terminé pour lui permettre de laisser un avis."
                           style="-fx-font-size:12px;-fx-text-fill:#888;
                                  -fx-wrap-text:true;"/>

                    <!-- Boutons état -->
                    <HBox spacing="14" alignment="CENTER_LEFT">
                        <Button fx:id="btnMarquerDone"
                                text="✅  Marquer DONE (voyage terminé)"
                                onAction="#handleMarquerDone"
                                style="-fx-background-color:#10b981;
                                       -fx-text-fill:white;-fx-font-weight:bold;
                                       -fx-padding:11 24;-fx-background-radius:10;
                                       -fx-cursor:hand;-fx-font-size:13px;"/>
                        <Button fx:id="btnMarquerNotDone"
                                text="⏳  Marquer NOT DONE"
                                onAction="#handleMarquerNotDone"
                                style="-fx-background-color:#f59e0b;
                                       -fx-text-fill:white;-fx-font-weight:bold;
                                       -fx-padding:11 24;-fx-background-radius:10;
                                       -fx-cursor:hand;-fx-font-size:13px;"/>
                        <Pane HBox.hgrow="ALWAYS"/>
                        <Button text="🔄 Actualiser"
                                onAction="#rafraichirTout"
                                style="-fx-background-color:white;
                                       -fx-text-fill:#FF6B35;
                                       -fx-border-color:#FF6B35;
                                       -fx-border-radius:10;-fx-background-radius:10;
                                       -fx-padding:10 20;-fx-font-weight:bold;
                                       -fx-cursor:hand;"/>
                    </HBox>

                    <!-- Table utilisateurs -->
                    <TableView fx:id="tableUtilisateurs" prefHeight="210"
                               style="-fx-background-radius:10;
                                      -fx-background-color:white;">
                        <columns>
                            <TableColumn fx:id="colUserId"
                                         text="ID"
                                         prefWidth="70"
                                         style="-fx-alignment:CENTER;"/>
                            <TableColumn fx:id="colUserEmail"
                                         text="Email"
                                         prefWidth="300"/>
                            <!-- ← colonne affiche id_voyage -->
                            <TableColumn fx:id="colUserVoyage"
                                         text="Voyage #"
                                         prefWidth="110"
                                         style="-fx-alignment:CENTER;"/>
                            <TableColumn fx:id="colUserEtat"
                                         text="État"
                                         prefWidth="160"
                                         style="-fx-alignment:CENTER;"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <!-- ══ SECTION 2 : Liste des avis ══ -->
                <VBox spacing="16"
                      style="-fx-background-color:white;-fx-background-radius:14;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),14,0,0,5);
                             -fx-padding:28;">

                    <Label text="📋 Liste des avis soumis"
                           style="-fx-font-size:18px;-fx-font-weight:bold;
                                  -fx-text-fill:#2c3e50;"/>

                    <!-- Boutons avis -->
                    <HBox spacing="14" alignment="CENTER_LEFT">
                        <Button fx:id="btnPublier"
                                text="✔  Valider l'avis"
                                onAction="#handlePublier"
                                style="-fx-background-color:#2ecc71;
                                       -fx-text-fill:white;-fx-font-weight:bold;
                                       -fx-padding:11 24;-fx-background-radius:10;
                                       -fx-cursor:hand;"/>
                        <Button fx:id="btnSupprimer"
                                text="🗑  Supprimer l'avis"
                                onAction="#handleSupprimer"
                                style="-fx-background-color:#e74c3c;
                                       -fx-text-fill:white;-fx-font-weight:bold;
                                       -fx-padding:11 24;-fx-background-radius:10;
                                       -fx-cursor:hand;"/>
                    </HBox>

                    <!-- Table avis -->
                    <TableView fx:id="tableAvis" prefHeight="300"
                               style="-fx-background-radius:10;
                                      -fx-background-color:white;">
                        <columns>
                            <TableColumn fx:id="idCol"
                                         text="ID"         prefWidth="45"
                                         style="-fx-alignment:CENTER;"/>
                            <TableColumn fx:id="userCol"
                                         text="User"       prefWidth="55"
                                         style="-fx-alignment:CENTER;"/>
                            <TableColumn fx:id="voyageCol"
                                         text="Voyage #"   prefWidth="75"
                                         style="-fx-alignment:CENTER;"/>
                            <TableColumn fx:id="titreCol"
                                         text="Titre"      prefWidth="140"/>
                            <TableColumn fx:id="noteCol"
                                         text="Note"       prefWidth="60"
                                         style="-fx-alignment:CENTER;"/>
                            <TableColumn fx:id="noteHebergementCol"
                                         text="Héberg."    prefWidth="75"
                                         style="-fx-alignment:CENTER;"/>
                            <TableColumn fx:id="noteTransportCol"
                                         text="Transport"  prefWidth="80"
                                         style="-fx-alignment:CENTER;"/>
                            <TableColumn fx:id="noteActivitesCol"
                                         text="Activités"  prefWidth="76"
                                         style="-fx-alignment:CENTER;"/>
                            <TableColumn fx:id="noteQualitePrixCol"
                                         text="Qual./Prix" prefWidth="85"
                                         style="-fx-alignment:CENTER;"/>
                            <TableColumn fx:id="recommandeCol"
                                         text="Recommande" prefWidth="95"
                                         style="-fx-alignment:CENTER;"/>
                            <TableColumn fx:id="dateCol"
                                         text="Date"       prefWidth="100"
                                         style="-fx-alignment:CENTER;"/>
                            <TableColumn fx:id="commentaireCol"
                                         text="Commentaire" prefWidth="200"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>