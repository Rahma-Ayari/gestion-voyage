<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import java.lang.String?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.CheckBox?>


<BorderPane prefHeight="608.0" prefWidth="773.0"
            style="-fx-background-color: linear-gradient(to bottom, #f5f7fa, #c3cfe2);"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.notificationsController">

    <top>
        <!-- HEADER -->
        <VBox spacing="0">
            <!-- Top bar with logo and title -->
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: linear-gradient(to right, #FF6B35, #F7931E); -fx-padding: 20 40 20 40;">
                <HBox alignment="CENTER" spacing="12">
                    <StackPane prefHeight="55" prefWidth="55" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 8, 0, 0, 3);">
                        <ImageView fx:id="logo" fitHeight="50" fitWidth="50" preserveRatio="true" smooth="true" />
                    </StackPane>
                    <Separator orientation="VERTICAL" prefHeight="40" style="-fx-background-color: rgba(255,255,255,0.3);" />
                </HBox>

                <!-- Title and subtitle -->
                <VBox alignment="CENTER_LEFT" spacing="3" HBox.hgrow="ALWAYS">
                    <Label fx:id="nomapp" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI', Arial; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 2, 0, 0, 1);" text="TripEase" textFill="white" />
                    <Label fx:id="nompage" text="Gestion des Notifications" textFill="rgba(255,255,255,0.95)">
                        <font>
                            <Font name="Segoe UI Semibold" size="15" />
                        </font>
                    </Label>
                </VBox>

                <!-- Right info -->
                <HBox alignment="CENTER_RIGHT" spacing="15">
                    <Label style="-fx-font-size: 13px; -fx-padding: 8 15;
                    -fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 20;"
                           text="👤 admin" textFill="white" />
                </HBox>
            </HBox>

            <!-- Secondary navigation bar -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: white;
            -fx-padding: 12 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                <Label fx:id="accueil" style="-fx-font-size: 13px; -fx-text-fill: #666;
                -fx-padding: 5 15; -fx-cursor: hand;" text="🏠 Accueil" />
                <Label style="-fx-text-fill: #ccc;" text="&gt;" />
                <Label fx:id="notifpage" style="-fx-font-size: 13px; -fx-text-fill: #FF6B35; -fx-font-weight: bold; -fx-padding: 5 15;" text="Notifications" />
            </HBox>
        </VBox>
    </top>

    <!-- Center Panel - Notifications -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color:transparent;">
        <content>
            <VBox fx:id="notificationsContainer"
                  spacing="15"
                  style="-fx-background-color:white; -fx-background-radius:12; -fx-padding:20;">
            <padding>
                <Insets bottom="25" left="25" right="25" top="25" />
            </padding>

            <!-- Title -->
            <Label style="-fx-font-size:26px; -fx-font-weight:bold;" text="Notifications" />

            <HBox spacing="10" alignment="CENTER_LEFT">

                <Label text="Filtrer :" style="-fx-font-size:14px; -fx-font-weight:bold;"/>

                <ComboBox prefWidth="150" promptText="Type">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Toutes"/>
                            <String fx:value="Réservation"/>
                            <String fx:value="Paiement"/>
                            <String fx:value="Système"/>
                        </FXCollections>
                    </items>
                </ComboBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="✔ Tout marquer comme lu"
                        style="-fx-background-color:#FF6B35; -fx-text-fill:white; -fx-background-radius:8;"/>

            </HBox>

                <VBox alignment="CENTER" spacing="10">

                    <Label text="🔔"
                           style="-fx-font-size:60px; -fx-opacity:0.5;"/>

                    <Label text="Aucune notification"
                           style="-fx-font-size:16px; -fx-text-fill:#666;"/>

                </VBox>

        </VBox>
        </content>
        </ScrollPane>
    </center>
</BorderPane>
