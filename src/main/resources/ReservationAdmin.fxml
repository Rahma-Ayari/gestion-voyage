<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.ImageView?>

<BorderPane prefWidth="1100" prefHeight="700" minWidth="1100" minHeight="700"
            style="-fx-background-color: linear-gradient(to bottom, #f5f7fa, #c3cfe2);"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.ReservationAdminController">

    <!-- ================= HEADER ================= -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-color: linear-gradient(to right, #FF6B35, #F7931E);
                     -fx-background-radius: 0 0 15 15;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 5);">
            <padding>
                <Insets top="12" right="20" bottom="12" left="20"/>
            </padding>

            <Label text="TripEase" textFill="WHITE">
                <font><Font name="Segoe UI Bold" size="24"/></font>
            </Label>

            <Label text="Gestion des Réservations" textFill="WHITE">
                <font><Font name="Segoe UI" size="18"/></font>
            </Label>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="👤 Admin" textFill="white"
                   style="-fx-font-size: 11px; -fx-padding: 6 12;
                          -fx-background-color: rgba(255,255,255,0.2);
                          -fx-background-radius: 20;"/>
        </HBox>
    </top>

    <!-- ================= LEFT PANEL ================= -->
    <left>
        <VBox alignment="TOP_CENTER" maxWidth="260" spacing="10"
              style="-fx-background-color: white; -fx-background-radius: 15;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 5);">
            <padding>
                <Insets top="15" right="12" bottom="15" left="12"/>
            </padding>
            <VBox.margin>
                <Insets top="10" right="0" bottom="10" left="10"/>
            </VBox.margin>

            <!-- Titre filtres -->
            <Label text="🔍 Filtres">
                <font><Font name="Segoe UI Bold" size="16"/></font>
            </Label>

            <Separator/>

            <!-- Filtre statut -->
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="📌" style="-fx-font-size: 14px;"/>
                <ComboBox fx:id="statutFilter"
                          promptText="Tous les statuts"
                          prefWidth="200"
                          style="-fx-background-radius: 8; -fx-border-color: #ddd;
                                 -fx-border-radius: 8; -fx-padding: 4; -fx-font-size: 11px;"/>
            </HBox>

            <Separator/>

            <!-- Détails -->
            <Label text="📄 Détails">
                <font><Font name="Segoe UI Bold" size="14"/></font>
            </Label>

            <ScrollPane fitToWidth="true" prefHeight="180" hbarPolicy="NEVER"
                        style="-fx-background-color: transparent; -fx-background: transparent;
                               -fx-border-color: #eee; -fx-border-radius: 8; -fx-border-width: 1;">
                <VBox fx:id="detailsBox" spacing="4" style="-fx-padding: 8; -fx-background-color: #FAFAFA;">
                    <Label text="Sélectionnez une réservation\npour voir les détails"
                           style="-fx-text-fill: #BBB; -fx-font-size: 10px;" wrapText="true"/>
                </VBox>
            </ScrollPane>

            <Separator/>

            <!-- Actions -->
            <Label text="⚡ Actions">
                <font><Font name="Segoe UI Bold" size="14"/></font>
            </Label>

            <HBox spacing="8" alignment="CENTER">
                <VBox spacing="6">
                    <Button fx:id="accepterBtn"
                            text="✓ Accepter"
                            prefWidth="110" prefHeight="32"
                            onAction="#accepterReservation"
                            style="-fx-background-color: #4CAF50; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 11px;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>
                    <Button fx:id="refuserBtn"
                            text="✗ Refuser"
                            prefWidth="110" prefHeight="32"
                            onAction="#refuserReservation"
                            style="-fx-background-color: #f44336; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 11px;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>
                </VBox>
                <VBox spacing="6">
                    <Button fx:id="annulerBtn"
                            text="⊘ Annuler"
                            prefWidth="110" prefHeight="32"
                            onAction="#annulerReservation"
                            style="-fx-background-color: #9E9E9E; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 11px;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>
                    <Button text="🔄 Rafraîchir"
                            prefWidth="110" prefHeight="32"
                            onAction="#refreshTable"
                            style="-fx-background-color: #2196F3; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 11px;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>
                </VBox>
            </HBox>

            <!-- Info Panel -->
            <VBox spacing="5"
                  style="-fx-background-color: #FFF3E0; -fx-background-radius: 10;
                         -fx-border-color: #FF6B35; -fx-border-radius: 10; -fx-border-width: 2;">
                <padding>
                    <Insets top="8" right="10" bottom="8" left="10"/>
                </padding>
                <Label text="💡 Conseils">
                    <font><Font name="Segoe UI Bold" size="11"/></font>
                </Label>
                <Label wrapText="true"
                       text="• Sélectionnez une ligne&#10;• Filtrer par statut&#10;• Actions disponibles"
                       style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
            </VBox>

        </VBox>
    </left>

    <!-- ================= CENTER TABLE ================= -->
    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="15" left="10"/>
            </padding>

            <!-- Search Bar -->
            <HBox alignment="CENTER_LEFT" spacing="8"
                  style="-fx-background-color: white; -fx-background-radius: 10;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                <padding>
                    <Insets top="8" right="8" bottom="8" left="8"/>
                </padding>
                <Label text="🔍" style="-fx-font-size: 14px;"/>
                <TextField fx:id="searchField"
                           promptText="Rechercher par client, offre, statut..."
                           prefWidth="450"
                           style="-fx-background-radius: 8; -fx-border-color: #ddd;
                                  -fx-border-radius: 8; -fx-padding: 8; -fx-font-size: 11px;"/>
                <Button fx:id="refreshBtn" text="🔄" onAction="#refreshTable"
                        style="-fx-background-color: #FF6B35; -fx-text-fill: white;
                               -fx-font-size: 14px; -fx-background-radius: 50%;
                               -fx-padding: 6 10; -fx-cursor: hand;"/>
            </HBox>

            <!-- Table -->
            <TableView fx:id="tableView" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-background-radius: 10;
                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 5);">
                <columns>
                    <TableColumn fx:id="idCol"              text="N°"               prefWidth="40"/>
                    <TableColumn fx:id="clientCol"          text="Client"           prefWidth="100"/>
                    <TableColumn fx:id="offreCol"           text="Offre"            prefWidth="95"/>
                    <TableColumn fx:id="dateReservationCol" text="Date Rés."        prefWidth="85"/>
                    <TableColumn fx:id="dateVoyageCol"      text="Date Voy."        prefWidth="85"/>
                    <TableColumn fx:id="nbPersonnesCol"     text="Pers."            prefWidth="50"/>
                    <TableColumn fx:id="montantCol"         text="Montant"          prefWidth="75"/>
                    <TableColumn fx:id="statutCol"          text="Statut"           prefWidth="85"/>
                    <TableColumn fx:id="commentaireCol"     text="Commentaire"      prefWidth="120"/>
                </columns>
                <placeholder>
                    <Label text="Aucune réservation trouvée"/>
                </placeholder>
            </TableView>

            <!-- Stats Panel -->
            <HBox alignment="CENTER" spacing="15"
                  style="-fx-background-color: white; -fx-background-radius: 10;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                <padding>
                    <Insets top="10" right="12" bottom="10" left="12"/>
                </padding>

                <HBox spacing="4" alignment="CENTER_LEFT">
                    <Label text="📋 Total : ">
                        <font><Font name="Segoe UI Bold" size="11"/></font>
                    </Label>
                    <Label fx:id="totalLabel" text="0" textFill="#FF6B35">
                        <font><Font name="Segoe UI Bold" size="14"/></font>
                    </Label>
                </HBox>

                <HBox spacing="4" alignment="CENTER_LEFT">
                    <Label text="🟡 Attente : ">
                        <font><Font name="Segoe UI Bold" size="11"/></font>
                    </Label>
                    <Label fx:id="enAttenteLabel" text="0" textFill="#F7931E">
                        <font><Font name="Segoe UI Bold" size="14"/></font>
                    </Label>
                </HBox>

                <HBox spacing="4" alignment="CENTER_LEFT">
                    <Label text="✅ Acceptées : ">
                        <font><Font name="Segoe UI Bold" size="11"/></font>
                    </Label>
                    <Label fx:id="accepteesLabel" text="0" textFill="#4CAF50">
                        <font><Font name="Segoe UI Bold" size="14"/></font>
                    </Label>
                </HBox>

                <HBox spacing="4" alignment="CENTER_LEFT">
                    <Label text="❌ Refusées : ">
                        <font><Font name="Segoe UI Bold" size="11"/></font>
                    </Label>
                    <Label fx:id="refuseesLabel" text="0" textFill="#f44336">
                        <font><Font name="Segoe UI Bold" size="14"/></font>
                    </Label>
                </HBox>

                <HBox spacing="4" alignment="CENTER_LEFT">
                    <Label text="⊘ Annulées : ">
                        <font><Font name="Segoe UI Bold" size="11"/></font>
                    </Label>
                    <Label fx:id="annuleesLabel" text="0" textFill="#9E9E9E">
                        <font><Font name="Segoe UI Bold" size="14"/></font>
                    </Label>
                </HBox>
            </HBox>

        </VBox>
    </center>

</BorderPane>
