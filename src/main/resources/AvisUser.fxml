<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller.AvisUserController"
            stylesheets="@style.css"
            style="-fx-background-color: #FFF4EE;">

    <!-- ══════════════════════════════════════════════════════
         HEADER
         ══════════════════════════════════════════════════════ -->
    <top>
        <VBox>
            <HBox style="-fx-background-color: linear-gradient(to right, #FF7F50, #FF9A76); -fx-padding: 18 32;"
                  alignment="CENTER_LEFT" spacing="16">

                <!-- Logo à GAUCHE -->
                <HBox spacing="14" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <StackPane style="-fx-background-color: rgba(255,255,255,0.22); -fx-background-radius: 14;
                                      -fx-pref-width: 50; -fx-pref-height: 50;
                                      -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.12),6,0,0,2);">
                        <Label text="✈" style="-fx-font-size: 24px; -fx-text-fill: white;"/>
                    </StackPane>
                    <VBox spacing="1">
                        <Label text="TripEase"
                               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;
                                      -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.15),4,0,0,1);"/>
                        <Label text="Votre avis fait la différence"
                               style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.88);"/>
                    </VBox>
                </HBox>

                <!-- Bouton Retour à DROITE (AVANT le badge utilisateur) -->
                <Button fx:id="btnRetour" text="← Retour"
                        style="-fx-font-size:13px; -fx-padding:8 18;
                               -fx-background-color: rgba(255,255,255,0.2);
                               -fx-border-color: rgba(255,255,255,0.5); -fx-border-width:1.5;
                               -fx-border-radius:10; -fx-background-radius:10;
                               -fx-text-fill: white; -fx-font-weight:bold; -fx-cursor:hand;"/>

                <!-- Badge utilisateur à DROITE -->
                <HBox spacing="10" alignment="CENTER"
                      style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 40;
                             -fx-padding: 7 18 7 7; -fx-border-color: rgba(255,255,255,0.3);
                             -fx-border-width: 1; -fx-border-radius: 40;">
                    <StackPane style="-fx-background-color: white; -fx-background-radius: 50;
                                      -fx-pref-width: 36; -fx-pref-height: 36;
                                      -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.1),4,0,0,1);">
                        <Label fx:id="lblUserAvatar" text="U"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #FF7F50;"/>
                    </StackPane>
                    <Label fx:id="lblUserName" text="Bonjour, utilisateur"
                           style="-fx-text-fill: white; -fx-font-size: 13.5px; -fx-font-weight: bold;"/>
                </HBox>
            </HBox>

            <!-- Breadcrumb -->
            <HBox style="-fx-padding: 11 32; -fx-background-color: white;
                         -fx-border-color: #FFE8DC; -fx-border-width: 0 0 1 0;"
                  spacing="8" alignment="CENTER_LEFT">
                <Label text="🏠 Accueil"  style="-fx-text-fill: #bbb; -fx-font-size: 13px;"/>
                <Label text="›"           style="-fx-text-fill: #ddd; -fx-font-size: 13px;"/>
                <Label text="📝 Mon avis" style="-fx-text-fill: #FF7F50; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ══════════════════════════════════════════════════════
         CONTENU PRINCIPAL
         ══════════════════════════════════════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true"
                    style="-fx-background: #FFF4EE; -fx-background-color: #FFF4EE;">
            <VBox style="-fx-background-color: #FFF4EE;" alignment="TOP_CENTER">
                <padding><Insets top="44" right="32" bottom="64" left="32"/></padding>

                <!-- Titre page -->
                <VBox alignment="CENTER" spacing="6">
                    <padding><Insets bottom="32"/></padding>
                    <Label text="Partagez votre expérience"
                           style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label text="Votre avis compte et aide les futurs voyageurs ✈"
                           style="-fx-font-size: 14px; -fx-text-fill: #9e8a80;"/>
                </VBox>

                <!-- ══ GRANDE CARTE ══ -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 20;
                             -fx-effect: dropshadow(gaussian, rgba(255,127,80,0.1), 28, 0, 0, 8);"
                      maxWidth="940" alignment="TOP_CENTER">
                    <padding><Insets top="46" right="60" bottom="46" left="60"/></padding>

                    <VBox spacing="36" alignment="TOP_CENTER">

                        <!-- ══ 0. SÉLECTEUR DE VOYAGE ══ -->
                        <VBox spacing="14"
                              style="-fx-background-color: #FFF8F4; -fx-background-radius: 16;
                                     -fx-border-color: #FFD5BE; -fx-border-width: 1.5;
                                     -fx-border-radius: 16; -fx-padding: 22;">
                            <HBox spacing="14" alignment="CENTER_LEFT">
                                <StackPane style="-fx-background-color: linear-gradient(to bottom right,#FF7F50,#FF9A76);
                                                  -fx-background-radius: 12; -fx-pref-width: 46; -fx-pref-height: 46;
                                                  -fx-effect: dropshadow(gaussian,rgba(255,127,80,0.4),10,0,0,3);">
                                    <Label text="🗺" style="-fx-font-size: 22px;"/>
                                </StackPane>
                                <VBox spacing="2">
                                    <Label text="Voyage concerné"
                                           style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                    <Label text="Sélectionnez le voyage que vous souhaitez évaluer"
                                           style="-fx-font-size: 12px; -fx-text-fill: #b09080;"/>
                                </VBox>
                            </HBox>
                            <ComboBox fx:id="cmbVoyage" maxWidth="Infinity"
                                      promptText="Sélectionnez votre voyage..."/>
                        </VBox>

                        <!-- Séparateur décoratif -->
                        <HBox alignment="CENTER" spacing="12">
                            <Region style="-fx-background-color: #FFE0D0; -fx-pref-height: 1;" HBox.hgrow="ALWAYS"/>
                            <Label text="⭐" style="-fx-font-size: 14px; -fx-opacity: 0.55;"/>
                            <Region style="-fx-background-color: #FFE0D0; -fx-pref-height: 1;" HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <!-- ══ 1. NOTE GLOBALE ══ -->
                        <VBox alignment="CENTER" spacing="12"
                              style="-fx-background-color: #FFFBF8; -fx-background-radius: 16;
                                     -fx-border-color: #FFE8DC; -fx-border-width: 1;
                                     -fx-border-radius: 16; -fx-padding: 26 24;">
                            <Label text="Note globale de votre expérience"
                                   style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                            <HBox spacing="6" alignment="CENTER">
                                <Button fx:id="star1" text="★"
                                        style="-fx-font-size:46;-fx-background-color:transparent;-fx-text-fill:#E8D8D0;-fx-cursor:hand;-fx-padding:2;"/>
                                <Button fx:id="star2" text="★"
                                        style="-fx-font-size:46;-fx-background-color:transparent;-fx-text-fill:#E8D8D0;-fx-cursor:hand;-fx-padding:2;"/>
                                <Button fx:id="star3" text="★"
                                        style="-fx-font-size:46;-fx-background-color:transparent;-fx-text-fill:#E8D8D0;-fx-cursor:hand;-fx-padding:2;"/>
                                <Button fx:id="star4" text="★"
                                        style="-fx-font-size:46;-fx-background-color:transparent;-fx-text-fill:#E8D8D0;-fx-cursor:hand;-fx-padding:2;"/>
                                <Button fx:id="star5" text="★"
                                        style="-fx-font-size:46;-fx-background-color:transparent;-fx-text-fill:#E8D8D0;-fx-cursor:hand;-fx-padding:2;"/>
                            </HBox>
                            <Label fx:id="lblRating" text="Cliquez pour noter"
                                   style="-fx-font-size:13.5px;-fx-text-fill:#C0A090;-fx-font-weight:bold;"/>
                        </VBox>

                        <!-- Séparateur décoratif -->
                        <HBox alignment="CENTER" spacing="12">
                            <Region style="-fx-background-color: #FFE0D0; -fx-pref-height: 1;" HBox.hgrow="ALWAYS"/>
                            <Label text="📊" style="-fx-font-size: 13px; -fx-opacity: 0.55;"/>
                            <Region style="-fx-background-color: #FFE0D0; -fx-pref-height: 1;" HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <!-- ══ 2. ÉVALUATIONS DÉTAILLÉES ══ -->
                        <VBox spacing="16" alignment="TOP_LEFT">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Évaluations détaillées"
                                       style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label text="— notez chaque aspect"
                                       style="-fx-font-size: 12px; -fx-text-fill: #B09080;"/>
                            </HBox>

                            <!-- Hébergement -->
                            <VBox spacing="8"
                                  style="-fx-background-color:#FFF8F4; -fx-background-radius:12;
                                         -fx-border-color:#FFDFD0; -fx-border-width:1;
                                         -fx-border-radius:12; -fx-padding:16 18;">
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <StackPane style="-fx-background-color:linear-gradient(to bottom right,#FF6B6B,#FF8E53);
                                                      -fx-pref-width:40;-fx-pref-height:40;-fx-background-radius:10;
                                                      -fx-effect:dropshadow(gaussian,rgba(255,107,107,0.35),8,0,0,3);">
                                        <Label text="🏨" style="-fx-font-size:18px;"/>
                                    </StackPane>
                                    <VBox spacing="1" HBox.hgrow="ALWAYS">
                                        <Label text="Hébergement"
                                               style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#2c3e50;"/>
                                        <Label text="Qualité du logement"
                                               style="-fx-font-size:11px;-fx-text-fill:#B09080;"/>
                                    </VBox>
                                    <Label fx:id="lblHebergement" text="0/5"
                                           style="-fx-font-size:19px;-fx-font-weight:bold;-fx-text-fill:#FF6B6B;-fx-min-width:52;-fx-alignment:center-right;"/>
                                </HBox>
                                <Slider fx:id="sliderHebergement" styleClass="modern-slider,slider-hebergement"/>
                            </VBox>

                            <!-- Transport -->
                            <VBox spacing="8"
                                  style="-fx-background-color:#F5F9FF; -fx-background-radius:12;
                                         -fx-border-color:#D0E4FF; -fx-border-width:1;
                                         -fx-border-radius:12; -fx-padding:16 18;">
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <StackPane style="-fx-background-color:linear-gradient(to bottom right,#4A90E2,#357ABD);
                                                      -fx-pref-width:40;-fx-pref-height:40;-fx-background-radius:10;
                                                      -fx-effect:dropshadow(gaussian,rgba(74,144,226,0.35),8,0,0,3);">
                                        <Label text="🚗" style="-fx-font-size:18px;"/>
                                    </StackPane>
                                    <VBox spacing="1" HBox.hgrow="ALWAYS">
                                        <Label text="Transport"
                                               style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#2c3e50;"/>
                                        <Label text="Facilité de déplacement"
                                               style="-fx-font-size:11px;-fx-text-fill:#8090A0;"/>
                                    </VBox>
                                    <Label fx:id="lblTransport" text="0/5"
                                           style="-fx-font-size:19px;-fx-font-weight:bold;-fx-text-fill:#4A90E2;-fx-min-width:52;-fx-alignment:center-right;"/>
                                </HBox>
                                <Slider fx:id="sliderTransport" styleClass="modern-slider,slider-transport"/>
                            </VBox>

                            <!-- Activités -->
                            <VBox spacing="8"
                                  style="-fx-background-color:#FAF5FF; -fx-background-radius:12;
                                         -fx-border-color:#E0C8F0; -fx-border-width:1;
                                         -fx-border-radius:12; -fx-padding:16 18;">
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <StackPane style="-fx-background-color:linear-gradient(to bottom right,#9B59B6,#8E44AD);
                                                      -fx-pref-width:40;-fx-pref-height:40;-fx-background-radius:10;
                                                      -fx-effect:dropshadow(gaussian,rgba(155,89,182,0.35),8,0,0,3);">
                                        <Label text="🎯" style="-fx-font-size:18px;"/>
                                    </StackPane>
                                    <VBox spacing="1" HBox.hgrow="ALWAYS">
                                        <Label text="Activités"
                                               style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#2c3e50;"/>
                                        <Label text="Choses à faire et visiter"
                                               style="-fx-font-size:11px;-fx-text-fill:#9080A0;"/>
                                    </VBox>
                                    <Label fx:id="lblActivites" text="0/5"
                                           style="-fx-font-size:19px;-fx-font-weight:bold;-fx-text-fill:#9B59B6;-fx-min-width:52;-fx-alignment:center-right;"/>
                                </HBox>
                                <Slider fx:id="sliderActivites" styleClass="modern-slider,slider-activites"/>
                            </VBox>

                            <!-- Qualité/Prix -->
                            <VBox spacing="8"
                                  style="-fx-background-color:#FFFBF0; -fx-background-radius:12;
                                         -fx-border-color:#FFE5B0; -fx-border-width:1;
                                         -fx-border-radius:12; -fx-padding:16 18;">
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <StackPane style="-fx-background-color:linear-gradient(to bottom right,#F39C12,#E67E22);
                                                      -fx-pref-width:40;-fx-pref-height:40;-fx-background-radius:10;
                                                      -fx-effect:dropshadow(gaussian,rgba(243,156,18,0.35),8,0,0,3);">
                                        <Label text="💰" style="-fx-font-size:18px;"/>
                                    </StackPane>
                                    <VBox spacing="1" HBox.hgrow="ALWAYS">
                                        <Label text="Qualité / Prix"
                                               style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#2c3e50;"/>
                                        <Label text="Rapport qualité-prix global"
                                               style="-fx-font-size:11px;-fx-text-fill:#A09060;"/>
                                    </VBox>
                                    <Label fx:id="lblQualitePrix" text="0/5"
                                           style="-fx-font-size:19px;-fx-font-weight:bold;-fx-text-fill:#F39C12;-fx-min-width:52;-fx-alignment:center-right;"/>
                                </HBox>
                                <Slider fx:id="sliderQualitePrix" styleClass="modern-slider,slider-qualiteprix"/>
                            </VBox>
                        </VBox>

                        <!-- Séparateur décoratif -->
                        <HBox alignment="CENTER" spacing="12">
                            <Region style="-fx-background-color: #FFE0D0; -fx-pref-height: 1;" HBox.hgrow="ALWAYS"/>
                            <Label text="✏️" style="-fx-font-size: 13px; -fx-opacity: 0.55;"/>
                            <Region style="-fx-background-color: #FFE0D0; -fx-pref-height: 1;" HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <!-- ══ 3. TITRE + COMMENTAIRE ══ -->
                        <VBox spacing="18" alignment="TOP_LEFT">
                            <Label text="Rédigez votre avis"
                                   style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                            <VBox spacing="6">
                                <HBox spacing="5" alignment="CENTER_LEFT">
                                    <Label text="📌" style="-fx-font-size: 12px;"/>
                                    <Label text="Titre de votre avis"
                                           style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#4A3530;"/>
                                    <Label text="*"
                                           style="-fx-text-fill:#FF7F50;-fx-font-weight:bold;-fx-font-size:14px;"/>
                                </HBox>
                                <TextField fx:id="txtTitre"
                                           promptText="Résumez votre expérience en quelques mots..."/>
                            </VBox>

                            <VBox spacing="6">
                                <HBox spacing="5" alignment="CENTER_LEFT">
                                    <Label text="💬" style="-fx-font-size: 12px;"/>
                                    <Label text="Votre commentaire"
                                           style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#4A3530;"/>
                                    <Label text="*"
                                           style="-fx-text-fill:#FF7F50;-fx-font-weight:bold;-fx-font-size:14px;"/>
                                </HBox>
                                <TextArea fx:id="txtCommentaire"
                                          promptText="Partagez les détails de votre voyage : ce que vous avez aimé, vos recommandations..."
                                          wrapText="true" prefHeight="140"/>
                                <HBox alignment="CENTER_RIGHT">
                                    <Label fx:id="lblCharCount" text="0/1000"
                                           style="-fx-font-size:11px;-fx-text-fill:#C0A898;"/>
                                </HBox>
                            </VBox>
                        </VBox>

                        <!-- Séparateur décoratif -->
                        <HBox alignment="CENTER" spacing="12">
                            <Region style="-fx-background-color: #FFE0D0; -fx-pref-height: 1;" HBox.hgrow="ALWAYS"/>
                            <Label text="👍" style="-fx-font-size: 13px; -fx-opacity: 0.55;"/>
                            <Region style="-fx-background-color: #FFE0D0; -fx-pref-height: 1;" HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <!-- ══ 4. RECOMMANDATION ══ -->
                        <VBox spacing="14" alignment="CENTER"
                              style="-fx-background-color: #FFF8F4; -fx-background-radius: 16;
                                     -fx-border-color: #FFD5BE; -fx-border-width: 1;
                                     -fx-border-radius: 16; -fx-padding: 26;">
                            <Label text="Recommanderiez-vous cette destination ?"
                                   style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#2c3e50;"/>
                            <Label text="Votre recommandation aide les autres voyageurs à choisir"
                                   style="-fx-font-size:12px;-fx-text-fill:#B09080;"/>
                            <HBox spacing="22" alignment="CENTER">
                                <padding><Insets top="4"/></padding>
                                <ToggleButton fx:id="btnOui" text="✓  Oui, je recommande"
                                              style="-fx-font-size:14px;-fx-padding:12 34;
                                                     -fx-background-color:white;
                                                     -fx-border-color:#10b981;-fx-border-width:2;
                                                     -fx-border-radius:12;-fx-background-radius:12;
                                                     -fx-text-fill:#10b981;-fx-font-weight:bold;-fx-cursor:hand;"/>
                                <ToggleButton fx:id="btnNon" text="✗  Non"
                                              style="-fx-font-size:14px;-fx-padding:12 34;
                                                     -fx-background-color:white;
                                                     -fx-border-color:#ef4444;-fx-border-width:2;
                                                     -fx-border-radius:12;-fx-background-radius:12;
                                                     -fx-text-fill:#ef4444;-fx-font-weight:bold;-fx-cursor:hand;"/>
                            </HBox>
                        </VBox>

                        <!-- ══ 5. BOUTONS D'ACTION ══ -->
                        <HBox spacing="18" alignment="CENTER">
                            <padding><Insets top="6" bottom="4"/></padding>
                            <Button fx:id="btnAnnuler" text="Annuler"
                                    style="-fx-font-size:14px;-fx-padding:13 46;
                                           -fx-background-color:white;
                                           -fx-border-color:#D8C8C0;-fx-border-width:2;
                                           -fx-border-radius:12;-fx-background-radius:12;
                                           -fx-text-fill:#8A7068;-fx-font-weight:bold;-fx-cursor:hand;"/>
                            <Button fx:id="btnPublier" text="  ✈  PUBLIER MON AVIS  "
                                    style="-fx-font-size:14.5px;-fx-padding:13 46;
                                           -fx-background-color:linear-gradient(to right,#FF7F50,#FF9A76);
                                           -fx-text-fill:white;-fx-background-radius:12;
                                           -fx-font-weight:bold;-fx-cursor:hand;
                                           -fx-effect:dropshadow(gaussian,rgba(255,127,80,0.5),16,0,0,5);"/>
                        </HBox>

                    </VBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
